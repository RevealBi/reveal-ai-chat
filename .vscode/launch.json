{
  // Open this folder in VS Code, then press F5 to build and run ONLY the server (API on :7654,
  // debugger attached). Start the client and database separately (see README "Run from source"):
  //   cd client && npm run dev     # Vite dev server on :5173 — open this in your browser
  //   docker compose up -d         # Postgres (seeds on first run)
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Reveal AI Chat (ASP.NET server)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/server/aspnet/RevealAIChat.Server/bin/Debug/net8.0/RevealAIChat.Server.dll",
      "cwd": "${workspaceFolder}/server/aspnet/RevealAIChat.Server",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        // Running the DLL directly doesn't read launchSettings.json, so set the port here to match
        // it (and serverUrl.ts on the client).
        "ASPNETCORE_URLS": "http://localhost:7654"
      }
    }
  ]
}
