# Copy this file to `.env` and fill in your values. docker-compose.app.yml reads it.
# (.env is gitignored — your keys never get committed.)

# Your OpenAI API key (the AI calls your model with your key).
OPENAI_API_KEY=sk-your-openai-key

# Your Reveal SDK license key. The image ships without one — you bring your own.
REVEAL_LICENSE=your-reveal-sdk-license-key

# Optional: override the model (default gpt-4.1).
# OPENAI_MODEL=gpt-4.1
