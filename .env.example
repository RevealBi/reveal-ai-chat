# Copy this file to `.env` and fill in your values. docker-compose.app.yml reads it.
# (.env is gitignored — your keys never get committed.)

# AI provider: OpenAI | Anthropic | AzureOpenAI.
AI_PROVIDER=OpenAI

# Your AI provider API key (the AI calls your model with your key).
AI_API_KEY=sk-your-key

# Your Reveal SDK license key. The image ships without one — you bring your own.
REVEAL_LICENSE=your-reveal-sdk-license-key

# Optional: pin a model (else the provider default is used).
# AI_MODEL=gpt-5.5

# Azure OpenAI only — the resource endpoint + deployment name.
# AI_ENDPOINT=https://your-resource.openai.azure.com
# AI_DEPLOYMENT=my-gpt-deployment
